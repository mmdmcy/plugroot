# Copy to $PLUGROOT_STATE_ROOT/.env and adjust for your host.
# Keep real .env files outside Git checkouts.
PLUGROOT_STATE_ROOT=/var/lib/plugroot
PLUGROOT_HOSTNAME=plugroot-host
PLUGROOT_PRIVATE_IP=127.0.0.1
PLUGROOT_USER=plugroot
PLUGROOT_REPO_DIR=/var/lib/plugroot/repos
PLUGROOT_WEB_BIND=127.0.0.1:8786
PLUGROOT_WEB_USER=plugroot
PLUGROOT_WEB_PASSWORD=
TZ=UTC
PUID=1000
PGID=1000
EXAMPLE_WEB_PORT=8080
