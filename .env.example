# Copy to .env and adjust for your host. Keep .env out of Git.
PLUGROOT_ROOT=/opt/plugroot
PLUGROOT_HOSTNAME=plugroot-host
PLUGROOT_PRIVATE_IP=127.0.0.1
PLUGROOT_USER=plugroot
PLUGROOT_REPO_DIR=/opt/plugroot/repos
PLUGROOT_WEB_BIND=127.0.0.1:8786
PLUGROOT_WEB_USER=plugroot
PLUGROOT_WEB_PASSWORD=
TZ=UTC
PUID=1000
PGID=1000
EXAMPLE_WEB_PORT=8080
VAULTWARDEN_DOMAIN=https://example-private-host.ts.net:8443
VAULTWARDEN_HTTP_PORT=8089
VAULTWARDEN_SIGNUPS_ALLOWED=false
