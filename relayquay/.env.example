# Copy this file to /var/lib/plugroot/relayquay/relayquay.env.
# Keep the copied file private and out of Git.

# Public hostname protected by Cloudflare Access.
RELAYQUAY_PUBLIC_HOST=rustdesk-wss.example.com

# Local loopback listener used by cloudflared.
RELAYQUAY_BIND=127.0.0.1
RELAYQUAY_LISTEN_PORT=8788

# Private state and existing RustDesk data.
RELAYQUAY_STATE_DIR=/var/lib/plugroot/relayquay
RUSTDESK_DATA_DIR=/var/lib/plugroot/rustdesk/data

# Existing RustDesk WebSocket upstreams.
RUSTDESK_HBBS_WS_UPSTREAM=127.0.0.1:21118
RUSTDESK_HBBR_WS_UPSTREAM=127.0.0.1:21119

# Cloudflare Tunnel token. Set this only in the private env file.
CLOUDFLARE_TUNNEL_TOKEN="<your-cloudflare-tunnel-token>"

# Optional RustDesk server profile. Leave COMPOSE_PROFILES unset for gateway-only.
RUSTDESK_SERVER_TAG=latest
RUSTDESK_HBBS_COMMAND="hbbs -r rustdesk-wss.example.com:443"
RUSTDESK_HBBR_COMMAND=hbbr

# Image tags.
CADDY_TAG=2-alpine
CLOUDFLARED_TAG=latest
