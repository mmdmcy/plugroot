#!/bin/sh
set -eu

root="${PLUGROOT_CODE_ROOT:-/opt/plugroot}"
bin="${PLUGROOT_BIN:-$root/bin/plugroot}"

if [ ! -x "$bin" ]; then
  if command -v plugroot >/dev/null 2>&1; then
    bin="$(command -v plugroot)"
  else
    echo "plugroot-tui: cannot find plugroot binary at $bin" >&2
    exit 127
  fi
fi

if [ "$(id -u)" -eq 0 ]; then
  exec "$bin" --root "$root" tui "$@"
fi

if command -v sudo >/dev/null 2>&1; then
  exec sudo "$bin" --root "$root" tui "$@"
fi

exec "$bin" --root "$root" tui "$@"
